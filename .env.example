# Supabase — Required (get from supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Razorpay — Optional for local dev (get from razorpay.com → Settings → API Keys)
# Use TEST mode keys (rzp_test_...) for development
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Razorpay Webhook Secret — Optional (get from razorpay.com → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Gemini AI — Optional (get from aistudio.google.com → Get API Key)
# Only needed for the AI attendance scan feature
GEMINI_API_KEY=your_gemini_api_key_here

# App URL — change to your production URL when deploying
NEXT_PUBLIC_APP_URL=http://localhost:3000
